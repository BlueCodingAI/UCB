# ── Disha backend environment ──────────────────────────────────────────────
# Copy to .env and fill in. Missing optional keys degrade gracefully (dev mode).

NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (SQLite file path)
DATABASE_PATH=./data/disha.sqlite
STORAGE_DIR=./storage

# Auth secrets (CHANGE in production)
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-too
OTP_PEPPER=change-me-otp-pepper
# Set Secure flag on auth cookies. MUST be false on plain HTTP (IP-only, no SSL),
# otherwise the browser drops the login cookie. Set to true once you add HTTPS.
COOKIE_SECURE=false
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# OpenAI (LLM + embeddings). Without a key, the app runs in dev RAG mode.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# OpenAI document-understanding engine (Files + Vector Store + Responses API).
# Uploads KB files to OpenAI at index time; used as fallback when local RAG is uncertain.
OPENAI_FILE_SEARCH=true
# Recommended: false — local RAG + structured institute lookup first, OpenAI PDF fallback.
# Set true only if you want chat to skip local SQLite RAG entirely.
OPENAI_PDF_ONLY=false
OPENAI_DOC_MODEL=gpt-4o
# If total active KB text (chars) is at or below this, send full files in context
# (~70K tokens ≈ 280000 chars; stays within gpt-4o's 128K window). Above it, use file_search.
KB_WHOLE_FILE_MAX_CHARS=280000
# Max chunks file_search returns per query (large-KB mode).
RAG_FILE_SEARCH_MAX_RESULTS=30

# LlamaCloud / LlamaParse — optional, expensive for large PDFs. Leave disabled unless needed.
# LLAMA_CLOUD_ENABLED=true + API key → agentic PDF parse at index time (per-page cost).
LLAMA_CLOUD_ENABLED=false
LLAMA_CLOUD_API_KEY=
LLAMA_CLOUD_PIPELINE_ID=
# Route OpenAI requests through an HTTP/HTTPS proxy (for restricted networks).
# Toggle on/off without removing the URL. URL form: http(s)://[user:pass@]host:port
OPENAI_PROXY_ENABLED=false
OPENAI_PROXY_URL=

# Sarvam AI (voice STT/TTS). Without a key, voice endpoints return 503.
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saarika:v2
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka

# Razorpay (INR payments). Without keys, a mock order flow is used in dev.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP). Without config, emails are logged to console in dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Disha CAP Guidance <no-reply@disha.local>

# Optional channels (disabled if absent)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
SMS_GATEWAY_KEY=

# CAP cycle / plan validity
CURRENT_CAP_YEAR=2026
ADMISSION_CUTOFF_DATE=2026-08-31

# Admin bootstrap (seeded super admin)
ADMIN_BOOTSTRAP_EMAIL=admin@disha.local
ADMIN_BOOTSTRAP_PASSWORD=Admin@12345
ADMIN_BOOTSTRAP_NAME=Disha Admin

# RAG tuning — higher TOP_K helps institute/seat-matrix lookups
RAG_TOP_K=15
RAG_MIN_SCORE=0.3

# Ops
SEASON_MODE=false
LOG_LEVEL=debug
